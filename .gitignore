# --- Jekyll / Ruby ---
/website/_site/
.jekyll-cache/
.bundle/
vendor/

# バックアップなので追跡しなくてよい
_design/

# ミラー先は追跡しない（自動生成物）
website/translations/

# 生成ログは追跡しない
