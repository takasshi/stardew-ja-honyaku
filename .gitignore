# translations: サンプル/配布不要ファイルは無視
translations/**/i18n/default.json

# 依存ファイル
Gemfile.lock

# --- System / Editor files ---
.DS_Store
Thumbs.db
*.bak
*.tmp
*.txt

# --- Node / NPM (将来導入時の保険) ---
node_modules/
